    "DemoLambdaVersioniVIyuSOSvoihLTA5jd4luj0G03DkQXxd3OD92hGp8g": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "DemoLambdaFunction"
        },
        "CodeSha256": "9dd78795f0359b8fad58a6fd0a554d98c19e991308c250cd0ef829e232adfa78",
        "Description": "Triggering fargate instance for scraping"
      }
    },
    "DemoEventsRuleSchedule1": {
      "Type": "AWS::Events::Rule",
      "Properties": {
        "ScheduleExpression": "cron(0 14 * * ? *)",
        "State": "ENABLED",
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "DemoLambdaFunction",
                "Arn"
              ]
            },
            "Id": "demoSchedule"
          }
        ]
      }
    },
    "DemoLambdaPermissionEventsRuleSchedule1": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Fn::GetAtt": [
            "DemoLambdaFunction",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "events.amazonaws.com",
        "SourceArn": {
          "Fn::GetAtt": [
            "DemoEventsRuleSchedule1",
            "Arn"
          ]
        }
      }
    }
  },
  "Outputs": {
    "ServerlessDeploymentBucketName": {
      "Value": "serverless-framework-deployments-us-east-2-16c6abd8-093f",
